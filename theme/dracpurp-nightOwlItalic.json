{
    "$schema": "vscode://schemas/color-theme",
    "name": "Dracpurp (Night Owl Italic)",
    "author": "simwai",
    "maintainers": [
        "simwai"
    ],
    "semanticClass": "theme.dracpurp",
    "semanticHighlighting": true,
    "dracula": {
        "base": [
            "#100e12",
            "#e8e8e8",
            "#2d074496",
            "#817B93",
            "#A8B4C3",
            "#A1D3A9",
            "#DEAC77",
            "#F272BE",
            "#B2A1E5",
            "#FF5555",
            "#CEC8B9"
        ],
        "ansi": [
            "#11021a",
            "#FF8585",
            "#3EC25F",
            "#DE9C3E",
            "#C095FC",
            "#FF79C6",
            "#6CB5C4",
            "#e8e8e8",
            "#8b6b9e",
            "#FF8585",
            "#3EC25F",
            "#DE9C3E",
            "#FF79C6",
            "#FF79C6",
            "#6CB5C4",
            "#ffffff"
        ],
        "brightOther": [
            "#AAB063",
            "#6CB5C4"
        ],
        "other": [
            "#2d074480",
            "#35094e40",
            "#ffffff",
            "#2d074460",
            "#1b0429",
            "#11021a",
            "#100e12",
            "#0e0217"
        ]
    },
    "colors": {
        "editor.background": "#100e12",
        "editor.foreground": "#e8e8e8"
    },
    "tokenColors": [
        {
            "name": "State (Variables, Strings, Numbers)",
            "scope": [
                "variable",
                "variable.other.readwrite",
                "variable.other.object",
                "variable.other.property",
                "support.variable.property",
                "string",
                "constant.numeric",
                "constant.language",
                "constant.other",
                "constant.other.key.perl"
            ],
            "settings": {
                "foreground": "#CEC8B9"
            }
        },
        {
            "name": "Behavior (Functions and Methods)",
            "scope": [
                "entity.name.function",
                "support.function"
            ],
            "settings": {
                "foreground": "#A1D3A9"
            }
        },
        {
            "name": "Skeleton (Keywords)",
            "scope": [
                "keyword",
                "storage.type",
                "storage.modifier"
            ],
            "settings": {
                "foreground": "#F272BE",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Pass-through (Parameters)",
            "scope": [
                "variable.parameter",
                "entity.name.variable.parameter"
            ],
            "settings": {
                "foreground": "#DEAC77",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Structural Engines (Classes and Namespaces)",
            "scope": [
                "entity.name.type.class",
                "entity.name.type.module",
                "entity.name.type.namespace"
            ],
            "settings": {
                "foreground": "#B2A1E5"
            }
        },
        {
            "name": "Data Shapes (Types and Enums)",
            "scope": [
                "entity.name.type",
                "support.type",
                "entity.name.type.interface",
                "entity.name.type.enum",
                "entity.name.type.struct"
            ],
            "settings": {
                "foreground": "#A8B4C3"
            }
        },
        {
            "name": "Passive Meta (Comments)",
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#817B93",
                "fontStyle": "italic"
            }
        },
        {
            "name": "CSS / SCSS function calls (Fallback)",
            "scope": [
                "support.function",
                "entity.name.function"
            ],
            "settings": {
                "foreground": "#A1D3A9"
            }
        }
    ],
    "semanticTokenColors": {
        "variable": "#CEC8B9",
        "property": "#CEC8B9",
        "string": "#CEC8B9",
        "number": "#CEC8B9",
        "regexp": "#CEC8B9",
        "parameter": {
            "foreground": "#DEAC77",
            "fontStyle": "italic"
        },
        "method": "#A1D3A9",
        "function": "#A1D3A9",
        "keyword": {
            "foreground": "#F272BE",
            "fontStyle": "italic"
        },
        "class": "#B2A1E5",
        "interface": "#B2A1E5",
        "namespace": "#B2A1E5",
        "type": "#A8B4C3",
        "enum": "#A8B4C3",
        "struct": "#A8B4C3",
        "typeParameter": "#A8B4C3",
        "comment": {
            "foreground": "#817B93",
            "fontStyle": "italic"
        }
    }
}