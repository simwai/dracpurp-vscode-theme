  "license": "MIT",
  "scripts": {
    "build": "node ./scripts/build.js",
    "lint": "node ./scripts/check-colors.js && node ./scripts/lint.js",
    "format": "biome check --write .",
    "format-unsafe": "biome check --write --unsafe .",
    "screenshots": "node ./scripts/generate-screenshots.js",
    "release": "node --env-file=.env ./node_modules/semantic-release/bin/semantic-release.js --no-ci",
    "generate-screenshots": "pnpm run build && pnpm run screenshots",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/simwai/dracpurp"
  },
  "packageManager": "pnpm",
